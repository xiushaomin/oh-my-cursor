{
  "schemaVersion": "1",
  "productVersion": "0.1.0",
  "defaults": {
    "maxRuleIds": 2,
    "maxPackIds": 2,
    "routerAgentLimit": 3
  },
  "profiles": [
    {
      "id": "planning",
      "agentIds": [
        "pm-planner",
        "question-asker"
      ],
      "include": {
        "workflowSummary": true,
        "workflowDeliverables": true,
        "packRules": false,
        "checkLane": false
      },
      "focus": "Clarify goals, constraints, sequencing, and only the minimum open questions needed to unblock execution.",
      "outputHints": [
        "goals",
        "milestones",
        "open_questions",
        "risks"
      ]
    },
    {
      "id": "research",
      "agentIds": [
        "repo-researcher",
        "debug-investigator"
      ],
      "include": {
        "workflowSummary": true,
        "workflowDeliverables": true,
        "packRules": true,
        "checkLane": true
      },
      "focus": "Read narrowly, map the repo with evidence, and return only concrete findings that help the parent decide the next move.",
      "outputHints": [
        "findings",
        "files_of_interest",
        "evidence",
        "next_steps"
      ]
    },
    {
      "id": "implementation",
      "agentIds": [
        "frontend-engineer",
        "java-backend-engineer",
        "ios-engineer",
        "android-engineer",
        "flutter-engineer",
        "react-native-engineer"
      ],
      "include": {
        "workflowSummary": true,
        "workflowDeliverables": true,
        "packRules": true,
        "checkLane": true
      },
      "focus": "Implement the smallest change that satisfies the assigned scope while preserving the repo's stack conventions and boundaries.",
      "outputHints": [
        "status",
        "files_changed",
        "checks_run",
        "risks"
      ]
    },
    {
      "id": "review",
      "agentIds": [
        "frontend-qa-reviewer",
        "backend-qa-reviewer",
        "mobile-qa-reviewer",
        "architecture-reviewer",
        "migration-reviewer",
        "test-writer"
      ],
      "include": {
        "workflowSummary": true,
        "workflowDeliverables": true,
        "packRules": true,
        "checkLane": true
      },
      "focus": "Produce findings first, keep them evidence-backed, and emphasize verification gaps, compatibility risk, and handoff clarity over narration.",
      "outputHints": [
        "findings",
        "severity",
        "verification",
        "handoffs"
      ]
    },
    {
      "id": "documentation",
      "agentIds": [
        "docs-maintainer"
      ],
      "include": {
        "workflowSummary": true,
        "workflowDeliverables": true,
        "packRules": false,
        "checkLane": true
      },
      "focus": "Turn completed technical work into concise repo docs, handoff notes, or reviewer-facing artifacts without adding unnecessary implementation noise.",
      "outputHints": [
        "summary",
        "verification",
        "risks",
        "handoffs"
      ]
    }
  ]
}
