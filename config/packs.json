    {
      "id": "omc-frontend",
      "title": "Frontend",
      "description": "React, Next.js, TypeScript, and modern web UI delivery.",
      "status": "active",
      "kind": "pack",
      "primarySkillId": "omc-frontend",
      "stack": {
        "platforms": [
          "web"
        ],
        "frameworks": [
          "react",
          "next.js"
        ],
        "languages": [
          "typescript",
          "javascript"
        ],
        "signals": [
          "package.json:react",
          "next.config.",
          "vite.config."
        ]
      },
      "compatibility": {
        "workflowIds": [
          "omc-orchestrate",
          "omc-brainstorm",
          "omc-work",
          "omc-review",
          "omc-debug",
          "omc-plan",
          "omc-architecture",
          "omc-scm",
          "omc-test-plan",
          "omc-pr-summary",
          "omc-release-checklist",
          "omc-incident-report",
          "omc-migration-checklist"
        ],
        "defaultWorkflowIds": [
          "omc-plan",
          "omc-work"
        ]
      },
      "assets": {
        "agentIds": [
          "frontend-engineer",
          "frontend-qa-reviewer"
        ],
        "ruleIds": [
          "rule.common-core",
          "rule.frontend-core",
          "rule.next-app-router"
        ]
      },
      "qualityFocus": [
        "accessibility",
        "performance",
        "testing",
        "design-systems"
      ],
      "packHeuristics": {
        "repoSignals": [
          "package.json:react",
          "package.json:next",
          "next.config.*",
          "vite.config.*"
        ],
        "fileGlobs": [
          "**/components/**/*.tsx",
          "**/src/**/*.tsx",
          "**/app/**/*.tsx"
        ],
        "keywords": [
          "react",
          "next",
          "tailwind",
          "frontend",
          "ui"
        ]
      },
      "explain": {
        "whenToUse": [
          "Web UI work",
          "Component systems"
        ],
        "whenNotToUse": [
          "Pure mobile native without web UI"
        ],
        "relatedPackIds": [
          "omc-react-native"
        ]
      }
    },
