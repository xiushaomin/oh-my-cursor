    {
      "id": "omc-frontend",
      "title": "Frontend",
      "description": "Web UI domain pack for React, Next.js, TypeScript, client data flow, design-system consistency, and accessibility-sensitive frontend work.",
      "status": "active",
      "kind": "pack",
      "primarySkillId": "omc-frontend",
      "stack": {
        "platforms": [
          "web"
        ],
        "frameworks": [
          "react",
          "next.js"
        ],
        "languages": [
          "typescript",
          "javascript"
        ],
        "signals": [
          "package.json:react",
          "next.config.",
          "vite.config."
        ]
      },
      "compatibility": {
        "workflowIds": [
          "omc-brainstorm",
          "omc-spec",
          "omc-plan",
          "omc-develop",
          "omc-verify",
          "omc-review",
          "omc-architecture",
          "omc-parallel",
          "omc-debug",
          "omc-learn"
        ],
        "defaultWorkflowIds": [
          "omc-plan",
          "omc-develop"
        ]
      },
      "assets": {
        "agentIds": [
          "frontend-engineer",
          "frontend-qa-reviewer"
        ],
        "ruleIds": [
          "rule.common-core",
          "rule.frontend-core",
          "rule.next-app-router"
        ]
      },
      "qualityFocus": [
        "accessibility",
        "performance",
        "testing",
        "design-systems"
      ],
      "packHeuristics": {
        "repoSignals": [
          "package.json:react",
          "package.json:next",
          "next.config.*",
          "vite.config.*"
        ],
        "fileGlobs": [
          "**/components/**/*.tsx",
          "**/src/**/*.tsx",
          "**/app/**/*.tsx"
        ],
        "keywords": [
          "react",
          "next",
          "tailwind",
          "frontend",
          "ui"
        ]
      },
      "explain": {
        "whenToUse": [
          "React or Next.js web UI work",
          "Component, route, styling, or client data-flow changes"
        ],
        "whenNotToUse": [
          "Pure native mobile work without a web UI surface"
        ],
        "relatedPackIds": [
          "omc-react-native"
        ]
      }
    },
